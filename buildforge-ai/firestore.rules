rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Secure mode (recommended): the browser may READ its own entitlement, but
    // only the trusted backend (Cloud Functions, via the Admin SDK) may WRITE it.
    // This makes purchased tiers tamper-proof — a user cannot grant themselves a plan.
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // ── Client-only fallback (NO backend) ────────────────────────────────────
    // If you are NOT deploying the Cloud Functions backend and instead rely on
    // the legacy client-side unlock, replace the write rule above with:
    //
    //   allow write: if request.auth != null && request.auth.uid == uid;
    //
    // Note: that fallback is convenient but NOT tamper-proof.
  }
}
